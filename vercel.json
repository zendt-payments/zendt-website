{
  "framework": "vite",
  "functions": {
    "api/email/webhook.ts": {
      "runtime": "@vercel/node@5.7.0",
      "maxDuration": 30
    },
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.7.0",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
