{
  "framework": "vite",
  "functions": {
    "api/email/webhook.ts": {
      "runtime": "@vercel/node@5.7.0",
      "maxDuration": 30
    },
    "api/**/*.ts": {
      "runtime": "@vercel/node@5.7.0",
      "maxDuration": 10
    }
  },
  "redirects": [
    {
      "source": "/login",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/wp-content/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/wp-admin/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/about",
      "destination": "/about-us",
      "permanent": true
    },
    {
      "source": "/blog/",
      "destination": "/blog",
      "permanent": true
    },
    {
      "source": "/privacy",
      "destination": "/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/terms-and-conditions",
      "permanent": true
    },
    {
      "source": "/refund",
      "destination": "/refund-policy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap.xml"
    },
    {
      "source": "/rss.xml",
      "destination": "/api/rss.xml"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}