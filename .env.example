# ── Firebase (Frontend — public, used by Vite) ──────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Firebase Admin (Backend — secret, Vercel env vars only) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Blog API Key (Backend — secret, Vercel env vars only) ────
BLOG_API_KEY=

# ── Resend (Backend — secret, Vercel env vars only) ──────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ── Anthropic / Claude (Backend — secret, Vercel env vars only)
ANTHROPIC_API_KEY=
